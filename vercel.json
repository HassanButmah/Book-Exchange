{
  "version": 2,
  "buildCommand": "echo 'Build complete'",
  "functions": {
    "server/index.js": {
      "memory": 1024,
      "maxDuration": 30,
      "runtime": "@vercel/node@3.0.0"
    }
  },
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/(.*\\.js)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/(.*\\.css)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/index.js",
      "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"]
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/server/index.js"
    },
    {
      "src": "/frontend/(.*)",
      "dest": "/frontend/$1"
    },
    {
      "src": "/(?!api|uploads).*\\.(js|css|png|jpg|jpeg|gif|svg|ico|webp|woff|woff2|ttf)$",
      "dest": "/frontend/$1"
    },
    {
      "src": "/(?!api|uploads).*\\.html$",
      "dest": "/frontend/$1"
    },
    {
      "src": "^/$",
      "dest": "/frontend/index.html"
    }
  ]
}

