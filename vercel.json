{
  "version": 2,
  "buildCommand": "npm install",
  "functions": {
    "server/index.js": {
      "memory": 1024,
      "maxDuration": 30,
      "runtime": "@vercel/node@3.0.0"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "server/index.js"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "server/index.js"
    }
  ],
  "routes": [
    {
      "src": "/frontend/(.*)",
      "dest": "/frontend/$1"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|webp|woff|woff2|ttf))",
      "dest": "/frontend/$1"
    },
    {
      "src": "/(.*\\.html)",
      "dest": "/frontend/$1"
    },
    {
      "src": "^/$",
      "dest": "/frontend/index.html"
    }
  ]
}

